{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "档案文档生成器",
  "version": "0.1.0",
  "identifier": "com.to.archive-docx-client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "档案文档生成器",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBMTMwMjEwQTA0QzFEQUEKUldTcUhVeWdFQUlUeWdJSThUNUVYOFhUTitHTnU2aU92OVJwNTJBRUhhZU15b1NhRlVmc2d0eGsK",
      "endpoints": [
        "https://github.com/logyxiao/archive-docx-client/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
